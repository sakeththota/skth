---
// Catan number token: cream disc, big numeral, probability pips beneath.
// 6 & 8 render red (highest-probability rolls), matching the real game.
interface Props { n?: number; size?: number | string; }
const { n, size = 46 } = Astro.props;
const sz = typeof size === "number" ? `${size}px` : size;
const PIPS: Record<number, number> = { 2: 1, 3: 2, 4: 3, 5: 4, 6: 5, 8: 5, 9: 4, 10: 3, 11: 2, 12: 1 };
const pips = n ? (PIPS[n] ?? 0) : 0;
const hot = n === 6 || n === 8;
---
{n && (
  <div class:list={["tok", { "tok--hot": hot }]} style={`--sz:${sz}`}>
    <span class="tok-n">{n}</span>
    <span class="tok-pips">{Array.from({ length: pips }).map(() => <i />)}</span>
  </div>
)}
<style>
  .tok {
    width: var(--sz);
    height: var(--sz);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: calc(var(--sz) * 0.03);
    background: radial-gradient(circle at 38% 30%, #fbf1d6, #e7d2a4);
    box-shadow: 0 1px 3px rgba(44, 27, 14, 0.45), inset 0 0 0 2px rgba(44, 27, 14, 0.3);
    font-family: var(--gn-font-display, "Fraunces", Georgia, serif);
    color: #2c1b0e;
    line-height: 1;
    user-select: none;
  }
  .tok-n { font-weight: 900; font-size: calc(var(--sz) * 0.46); }
  .tok--hot .tok-n { color: #b5331f; }
  .tok-pips { display: flex; gap: calc(var(--sz) * 0.055); height: calc(var(--sz) * 0.07); }
  .tok-pips i { width: calc(var(--sz) * 0.07); height: calc(var(--sz) * 0.07); border-radius: 50%; background: #2c1b0e; }
  .tok--hot .tok-pips i { background: #b5331f; }
</style>
