---
import '@/styles/birthday.css';
const { pageTitle = "You're Invited — Game Night", variant = "" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="theme-color" content="#2C7191" />
  </head>
  <body class:list={["gn", variant]}>
    <div class="gn-frame">
      <main class="flex-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
